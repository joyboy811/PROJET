# PAGe Platform — Configuration d'environnement
# Copier ce fichier à .env et adapter les valeurs

# ── PostgreSQL ──────────────────────────
POSTGRES_DB=opage_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=akramsql

# ── Django (O-PAGe & M-PAGe) ──────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-here

# ── O-PAGe Backend ──────────────────────────
OPAGE_DB_NAME=opage_db
OPAGE_DB_USER=postgres
OPAGE_DB_PASSWORD=akramsql
OPAGE_DB_HOST=db
OPAGE_DB_PORT=5432

# ── M-PAGe Backend ──────────────────────────
MPAGE_DB_NAME=mpage_db
MPAGE_DB_USER=postgres
MPAGE_DB_PASSWORD=akramsql
MPAGE_DB_HOST=db
MPAGE_DB_PORT=5432

# ── Frontends ──────────────────────────
REACT_APP_API_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8001/api

# ── Docker ──────────────────────────
COMPOSE_PROJECT_NAME=page-platform
